<?xml version="1.0" encoding="utf-8"?>
<selector android:enterFadeDuration="200" android:exitFadeDuration="200"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <corners android:bottomLeftRadius="@dimen/card_background_radius" android:bottomRightRadius="@dimen/card_background_radius" />
            <solid android:color="@color/bg_item_category_select" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <corners android:bottomLeftRadius="@dimen/card_background_radius" android:bottomRightRadius="@dimen/card_background_radius" />
            <solid android:color="@color/bg_item_category_select" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/bg_item_category" />
        </shape>
    </item>
</selector>